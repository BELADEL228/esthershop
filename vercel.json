{
  "version": 2,
  "builds": [
    {
      "src": "src/**",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    },
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/webhook/fedapay",
      "dest": "/api/webhook/fedapay.js"
    },
    {
      "src": "/(.*)",
      "dest": "/"
    }
  ],
  "env": {
    "SUPABASE_URL": "@supabase_url",
    "SUPABASE_SERVICE_ROLE_KEY": "@supabase_service_role_key",
    "FEDAPAY_WEBHOOK_SECRET": "@fedapay_webhook_secret"
  }
}